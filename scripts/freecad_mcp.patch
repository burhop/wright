+def _resolve_freecad_cmd() -> str:
+    """Resolve the FreeCAD command-line executable path (cross-platform)."""
+    # On Linux snap, freecad.cmd is the headless entry point
+    if FREECAD_PATH.endswith(".cmd") or FREECAD_PATH.endswith("freecadcmd"):
+        return FREECAD_PATH
+    # Windows: FreeCAD.exe -> FreeCADCmd.exe
+    if FREECAD_PATH.endswith("FreeCAD.exe"):
+        return FREECAD_PATH.replace("FreeCAD.exe", "FreeCADCmd.exe")
+    # Fallback: use FREECAD_PATH as-is
+    return FREECAD_PATH
+
+
