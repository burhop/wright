# =============================================================================
# Wright — Development Docker Image
# =============================================================================
# Lightweight dev image for initial development before the thick base is ready.
# Uses plain Python + uv for fast iteration.
# =============================================================================

FROM python:3.13-slim AS dev

# Install uv for fast dependency management
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# System deps for common Python packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Copy only workspace config for dependency resolution
COPY pyproject.toml ./
COPY apps/api/pyproject.toml apps/api/pyproject.toml
COPY packages/core/pyproject.toml packages/core/pyproject.toml
COPY packages/agent_adapters/pyproject.toml packages/agent_adapters/pyproject.toml
COPY packages/tool_registry/pyproject.toml packages/tool_registry/pyproject.toml
COPY packages/data_vault/pyproject.toml packages/data_vault/pyproject.toml

# Install dependencies (source code is mounted as volumes, not copied)
RUN uv sync --no-install-workspace

# Application code is mounted via docker-compose volumes
# EXPOSE port only on localhost per constitution security requirements
EXPOSE 8000

CMD ["uv", "run", "uvicorn", "api.main:app", "--host", "127.0.0.1", "--port", "8000", "--reload"]
