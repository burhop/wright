# LLM API configuration (required for agent operation)
LLM_API_URL=https://your-llm-endpoint/v1
LLM_API_KEY=sk-your-key-here
LLM_API_MODEL=your-default-model

# Application Environment (development, production)
WRIGHT_ENV=production
WRIGHT_API_TOKEN=replace-with-output-of-openssl-rand-hex-32
WRIGHT_AUTH_MODE=enforced
WRIGHT_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8080,http://127.0.0.1:8080

# UI Theme Config (light, dark)
UI_THEME=dark
