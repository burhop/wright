# =============================================================================
# Wright - Thick Base Docker Image (SKELETON)
# =============================================================================
# This image contains all heavy engineering dependencies that rarely change.
# Application code is NOT baked in - it is mounted via docker-compose volumes.
#
# Target Hardware: Dell GB10 / NVIDIA DGX Spark (aarch64, 128GB unified memory)
#
# TODO: Build this image once the dependency list is finalized.
#       Expected build time: 1-3 hours (compiling CUDA, PyTorch, FreeCAD, etc.)
# =============================================================================

# --- Stage 1: CUDA + PyTorch base ---
# FROM nvidia/cuda:12.x-devel-ubuntu24.04 AS base
# RUN apt-get update && apt-get install -y python3.11 python3.11-venv ...

# --- Stage 2: Engineering tools ---
# FreeCAD (headless, for STEP/BREP manipulation)
# RUN apt-get install -y freecad-cmd

# CalculiX (finite element analysis via pycalculix)
# RUN apt-get install -y calculix-ccx

# CadQuery + Build123d (parametric CAD via Python)
# RUN pip install cadquery build123d

# PrusaSlicer CLI / CuraEngine (STL to G-code)
# RUN apt-get install -y prusa-slicer

# --- Stage 3: Python ML stack ---
# vLLM (local LLM inference)
# RUN pip install vllm

# PyTorch
# RUN pip install torch torchvision

# LanceDB (in-process vector database)
# RUN pip install lancedb

# --- Stage 4: Observability ---
# OpenTelemetry SDKs
# RUN pip install opentelemetry-api opentelemetry-sdk opentelemetry-exporter-otlp

# --- Runtime ---
# FROM base AS runtime
# WORKDIR /workspace
# The /apps and /packages directories are mounted as volumes, not copied
# EXPOSE 8000
# CMD ["uvicorn", "api.main:app", "--host", "127.0.0.1", "--port", "8000"]
